// 1.3 -- hierarchical Inheritance

#include <iostream>
using namespace std;
class Vehicle {
public:    
    void start() {
        cout <<"Vehicle starts..." <<"\n";
    }
};

class Bike : public Vehicle {
public:
    void drive() {
        cout << "Bike is running..." << "\n";
    }
};

class Car : public Vehicle {
public:
    void drive() {
        cout << "Car is running..." <<"\n";
    }
};

int main() {
    Car c;
    Bike b;
    c.start();
    c.drive();
    b.start();
    b.drive();
}
